# Copy to .env (gitignored) and adjust. EXPO_PUBLIC_* values are inlined into the bundle.

# Base URL of the Life RPG .NET API.
EXPO_PUBLIC_API_URL=http://localhost:5005

# Demo mode: when true the app runs fully local-first and never calls the backend.
# The hosted web demo ships with this true so it works without a live API.
EXPO_PUBLIC_DEMO_MODE=true
